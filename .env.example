# ---- InvoiceSnap Growth Engine config ----

# Production domain of InvoiceSnap (used to build URLs for indexing pings).
# Matches lib/site.ts in the invoicesnap repo. No trailing slash.
SITE_URL=https://invoicesnap.app

# How many new profession pages to add per scheduled run.
BATCH_SIZE=12

# IndexNow key (Bing/Yandex instant indexing). Generate any 8-128 char hex string,
# then host it at https://invoicesnap.app/<KEY>.txt (file contents = the key).
INDEXNOW_KEY=

# OPTIONAL: enables AI extension of the catalog so the engine never runs dry.
# If unset, the engine runs fully deterministically off data/catalog.ts.
ANTHROPIC_API_KEY=

# OPTIONAL: model for AI extension (default below).
ANTHROPIC_MODEL=claude-sonnet-4-6
